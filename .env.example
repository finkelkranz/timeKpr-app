# timekpr-app Environment Configuration
# 
# CRITICAL SECURITY SETTINGS - MUST BE SET BEFORE RUNNING
# Copy this file to .env and fill in the values
# .env is in .gitignore and will never be committed

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================
# CRITICAL: Bind to localhost only (127.0.0.1) for security
# Never use 0.0.0.0 or :: - this exposes the server to your entire network
HOST=127.0.0.1
PORT=8000
APP_ENV=development

# =============================================================================
# SECURITY - JWT TOKEN
# =============================================================================
# CRITICAL: Generate a strong random secret (64+ characters)
# Use: openssl rand -hex 64
# Or: python3 -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET=your_random_64_character_secret_here

# Token expiration in minutes (recommended: 15-60 for home use)
JWT_EXPIRE_MINUTES=15
JWT_ALGORITHM=HS256

# =============================================================================
# SECURITY - ADMIN PASSWORD
# =============================================================================
# CRITICAL: Set a strong admin password
# Generate hash with: python3 -c "from timekpr_app.auth import hash_password; print(hash_password('your_strong_password'))"
# NEVER use the default "admin" password in production
ADMIN_PASSWORD_HASH=your_bcrypt_password_hash_here

# =============================================================================
# CORS - Cross-Origin Resource Sharing
# =============================================================================
# Comma-separated list of allowed origins
# For home use with frontend on same machine: http://localhost:5173
CORS_ORIGINS=http://localhost:5173

# =============================================================================
# DATABASE
# =============================================================================
# SQLite database location (default is fine for most users)
# DB_DIR=/var/lib/timekpr-app-data
# DB_FILE=/var/lib/timekpr-app-data/stats.db
